PORT=3000
# Use NODE_ENV=production on Azure App Service so CORS only uses CORS_ORIGINS (not all localhost ports).
#NODE_ENV=production
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=your-database
AZURE_SQL_USER=your-admin-login
AZURE_SQL_PASSWORD=your-password
# Comma-separated origins for CORS (include your Static Web App URL)
CORS_ORIGINS=http://localhost:8080,https://your-app.azurestaticapps.net
